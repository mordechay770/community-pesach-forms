<!DOCTYPE html>
<html lang="ru" dir="ltr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>РџРµСЃР°С… 5786 вЂ” РҐР°Р±Р°Рґ РђР»РјР°С‚С‹</title>
  <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700;900&display=swap" rel="stylesheet">
  <style>
    :root {
      --navy:      #1B3A6B;
      --navy-2:    #2A4F8E;
      --navy-light:#E8EEF7;
      --gold:      #C9A84C;
      --gold-soft: #FBF3DF;
      --gold-dark: #A07820;
      --paper:     #FFFFFF;
      --soft:      #F8F6F0;
      --text:      #1A1A2E;
      --muted:     #6B7280;
      --line:      #E5E0D5;
      --shadow:    0 4px 20px rgba(27,58,107,0.12);
      --shadow-sm: 0 2px 8px rgba(27,58,107,0.08);
      --radius:    20px;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html { scroll-behavior: smooth; }

    body {
      font-family: 'Roboto', Arial, sans-serif;
      background: var(--soft);
      color: var(--text);
      min-height: 100vh;
    }

    /* в”Ђв”Ђ SHELL в”Ђв”Ђ */
    .info-shell {
      width: min(1020px, 94vw);
      margin: 24px auto 56px;
      display: grid;
      gap: 18px;
    }

    /* в”Ђв”Ђ HERO в”Ђв”Ђ */
    .info-hero {
      background: linear-gradient(135deg, var(--navy) 0%, var(--navy-2) 100%);
      color: #fff;
      padding: 36px 32px;
      border-radius: 28px;
      box-shadow: var(--shadow);
      position: relative;
      overflow: hidden;
    }
    .info-hero::after {
      content: 'рџЌ·';
      position: absolute;
      right: 28px; top: 50%;
      transform: translateY(-50%);
      font-size: 80px;
      opacity: 0.18;
      pointer-events: none;
    }
    .info-hero .eyebrow {
      display: inline-block;
      background: rgba(201,168,76,0.25);
      color: var(--gold);
      font-size: 12px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 1.2px;
      border-radius: 20px;
      padding: 4px 14px;
      margin-bottom: 14px;
    }
    .info-hero h1 {
      font-size: clamp(26px, 5vw, 40px);
      font-weight: 900;
      margin: 0 0 12px;
      line-height: 1.2;
    }
    .info-hero p {
      margin: 0;
      color: #edf3f8;
      line-height: 1.7;
      max-width: 600px;
      font-size: 15px;
    }

    /* в”Ђв”Ђ NAV в”Ђв”Ђ */
    .nav-panel {
      background: var(--paper);
      border: 1px solid var(--line);
      border-radius: 28px;
      box-shadow: var(--shadow-sm);
      padding: 18px 22px;
    }
    .nav-links {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
    }
    .nav-links a {
      text-decoration: none;
      padding: 9px 16px;
      border-radius: 999px;
      background: var(--gold-soft);
      color: var(--navy);
      border: 1px solid #dcc38b;
      font-weight: 700;
      font-size: 13px;
      transition: background .15s, transform .1s;
    }
    .nav-links a:hover {
      background: #f0e4c0;
      transform: translateY(-1px);
    }

    /* в”Ђв”Ђ SECTION PANEL в”Ђв”Ђ */
    .section-panel {
      background: var(--paper);
      border: 1px solid var(--line);
      border-radius: 28px;
      box-shadow: var(--shadow-sm);
      padding: 28px 28px;
    }
    .section-panel h2 {
      margin: 0 0 6px;
      color: var(--navy);
      font-size: 26px;
      font-weight: 800;
    }
    .section-panel .section-sub {
      color: var(--muted);
      font-size: 14px;
      margin-bottom: 20px;
    }
    .section-panel p {
      color: var(--muted);
      line-height: 1.75;
      margin-bottom: 14px;
    }
    .section-panel p:last-child { margin-bottom: 0; }

    /* в”Ђв”Ђ BULLET LIST в”Ђв”Ђ */
    .bullet-list {
      display: grid;
      gap: 10px;
      margin-top: 16px;
    }
    .bullet-list.cols-2 {
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    }
    .bullet {
      padding: 16px 18px;
      border-radius: 18px;
      background: var(--soft);
      border: 1px solid var(--line);
    }
    .bullet strong {
      display: block;
      margin-bottom: 6px;
      color: var(--navy);
      font-weight: 700;
    }
    .bullet span {
      color: var(--muted);
      line-height: 1.6;
      font-size: 14px;
    }
    .bullet.gold {
      background: var(--gold-soft);
      border-color: #dcc38b;
    }
    .bullet.gold strong { color: var(--gold-dark); }
    .bullet.navy {
      background: var(--navy-light);
      border-color: #c0d0e8;
    }
    .bullet.navy strong { color: var(--navy); }

    /* в”Ђв”Ђ DATES TABLE в”Ђв”Ђ */
    .dates-grid {
      display: grid;
      gap: 10px;
      margin-top: 16px;
    }
    .date-row {
      display: flex;
      align-items: center;
      gap: 16px;
      padding: 14px 18px;
      border-radius: 16px;
      background: var(--soft);
      border: 1px solid var(--line);
    }
    .date-row.highlight {
      background: var(--gold-soft);
      border-color: #dcc38b;
    }
    .date-badge {
      flex-shrink: 0;
      background: var(--navy);
      color: #fff;
      font-size: 12px;
      font-weight: 700;
      border-radius: 10px;
      padding: 4px 12px;
      text-align: center;
      min-width: 90px;
    }
    .date-row.highlight .date-badge {
      background: var(--gold-dark);
    }
    .date-info strong {
      display: block;
      color: var(--text);
      font-weight: 700;
      margin-bottom: 2px;
    }
    .date-info span {
      font-size: 13px;
      color: var(--muted);
    }

    /* в”Ђв”Ђ SEDER CARD в”Ђв”Ђ */
    .seder-cards {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
      gap: 14px;
      margin-top: 18px;
    }
    .seder-card {
      border-radius: 20px;
      padding: 22px 20px;
      text-align: center;
      border: 2px solid var(--gold);
      background: var(--gold-soft);
    }
    .seder-card .sc-num {
      font-size: 36px;
      font-weight: 900;
      color: var(--gold-dark);
      line-height: 1;
    }
    .seder-card .sc-label {
      font-size: 14px;
      color: var(--muted);
      margin: 4px 0 10px;
    }
    .seder-card .sc-date {
      font-size: 18px;
      font-weight: 700;
      color: var(--navy);
    }
    .seder-card .sc-time {
      font-size: 28px;
      font-weight: 900;
      color: var(--gold-dark);
      margin: 4px 0;
    }
    .seder-card .sc-addr {
      font-size: 12px;
      color: var(--muted);
      margin-top: 8px;
      line-height: 1.5;
    }

    /* в”Ђв”Ђ FAIR BLOCK в”Ђв”Ђ */
    .fair-block {
      background: linear-gradient(135deg, var(--navy) 0%, var(--navy-2) 100%);
      border-radius: 20px;
      padding: 24px 24px;
      color: #fff;
      margin-top: 16px;
    }
    .fair-block h3 {
      font-size: 18px;
      font-weight: 800;
      margin-bottom: 6px;
    }
    .fair-block p {
      color: #d0dcea;
      font-size: 14px;
      line-height: 1.65;
      margin-bottom: 14px;
    }
    .fair-items {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }
    .fair-item {
      background: rgba(255,255,255,0.12);
      border: 1px solid rgba(255,255,255,0.2);
      border-radius: 20px;
      padding: 6px 14px;
      font-size: 13px;
      font-weight: 600;
    }

    /* в”Ђв”Ђ CONTACT BLOCK в”Ђв”Ђ */
    .contact-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 12px;
      margin-top: 16px;
    }
    .contact-item {
      display: flex;
      align-items: flex-start;
      gap: 12px;
      padding: 16px;
      border-radius: 16px;
      background: var(--soft);
      border: 1px solid var(--line);
      text-decoration: none;
      color: var(--text);
      transition: box-shadow .15s, transform .1s;
    }
    .contact-item:hover {
      box-shadow: var(--shadow-sm);
      transform: translateY(-1px);
    }
    .contact-icon {
      font-size: 24px;
      flex-shrink: 0;
    }
    .contact-label {
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: .5px;
      color: var(--muted);
      margin-bottom: 3px;
    }
    .contact-value {
      font-size: 14px;
      font-weight: 700;
      color: var(--navy);
    }

    /* в”Ђв”Ђ DIVIDER в”Ђв”Ђ */
    .section-divider {
      width: 48px;
      height: 4px;
      background: var(--gold);
      border-radius: 2px;
      margin: 12px 0 20px;
    }

    @media (max-width: 520px) {
      .info-hero { padding: 24px 20px; }
      .section-panel { padding: 22px 18px; }
    }
  </style>
</head>
